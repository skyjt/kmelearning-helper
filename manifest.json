{
  "manifest_version": 3,
  "name": "KME Learning Navigator",
  "description": "Auto-play and continue KME learning pages while restoring the hidden player speed control.",
  "version": "2.5.0",
  "permissions": [
    "storage"
  ],
  "host_permissions": [
    "https://pc.kmelearning.com/*"
  ],
  "icons": {
    "16": "icons/icon-16.png",
    "32": "icons/icon-32.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  },
  "web_accessible_resources": [
    {
      "resources": [
        "icons/icon-32.png",
        "icons/icon-128.png"
      ],
      "matches": [
        "https://pc.kmelearning.com/*"
      ]
    }
  ],
  "content_scripts": [
    {
      "matches": [
        "https://pc.kmelearning.com/*"
      ],
      "js": [
        "content.js"
      ],
      "css": [
        "styles.css"
      ],
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_title": "KME 学习助手",
    "default_icon": {
      "16": "icons/icon-16.png",
      "32": "icons/icon-32.png",
      "48": "icons/icon-48.png",
      "128": "icons/icon-128.png"
    }
  }
}
